# Server Configuration
PORT=3000
NODE_ENV=development

# Security
API_KEY=your-64-char-hex-api-key-here
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# Firebase Configuration (PILIH SALAH SATU)
# Option A: Paste JSON string (untuk Vercel env vars)
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Option B: Path ke file (untuk local dev)
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# Cache Configuration
CACHE_TTL_MS=300000
CACHE_MAX_SIZE=500

# Logging
LOG_LEVEL=info

# CORS (production only)
ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# Optional: Redis for distributed cache (future)
# REDIS_URL=redis://localhost:6379